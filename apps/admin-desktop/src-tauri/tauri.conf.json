{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ERP Cloud Yönetim",
  "version": "1.0.0",
  "identifier": "com.erpcloud.admin",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ERP Cloud - Yedek Parça Yönetim Sistemi",
        "width": 1600,
        "height": 1000,
        "minWidth": 1280,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://*; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "ERP Cloud",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": ["tr-TR", "en-US"]
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.13",
      "exceptionDomain": ""
    },
    "externalBin": [],
    "copyright": "Copyright © 2026 ERP Cloud. Tüm hakları saklıdır.",
    "category": "Business",
    "shortDescription": "Yedek Parça Yönetim Sistemi",
    "longDescription": "ERP Cloud - Profesyonel yedek parça satış, stok ve müşteri yönetim sistemi. Tezgâh satış, fiyatlandırma, araç uyumluluk kontrolü ve raporlama özellikleri.",
    "licenseFile": null
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
