{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ERP Cloud Admin",
  "version": "0.1.0",
  "identifier": "com.polat1.erpcloud",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ERP Cloud Admin",
        "width": 1400,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "store": {
      "enabled": true
    }
  }
}
